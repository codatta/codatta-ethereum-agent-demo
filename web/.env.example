# Web Dashboard Configuration
# Copy to .env and modify for your deployment

# Invite Service backend URL
VITE_INVITE_SERVICE_URL=http://127.0.0.1:4060

# Blockchain RPC URL
VITE_RPC_URL=http://127.0.0.1:8086

# Chain ID (31337 = Anvil local, 84532 = Base Sepolia)
VITE_CHAIN_ID=31337

# Chain display name
VITE_CHAIN_NAME=Anvil Local

# Default provider ports (for deriving endpoints from base URL)
VITE_DEFAULT_PORT_WEB=4021
VITE_DEFAULT_PORT_MCP=4022
VITE_DEFAULT_PORT_A2A=4023
