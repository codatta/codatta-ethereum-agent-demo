# Network: "local" for Anvil, "sepolia" for Base Sepolia testnet
NETWORK=local

# Anvil default RPC
LOCAL_RPC_URL=http://127.0.0.1:8545
# Base Sepolia RPC (only used when NETWORK=sepolia). Pick any Base Sepolia
# endpoint, e.g. https://sepolia.base.org
SEPOLIA_RPC_URL=

# Private keys (Anvil defaults for local testing)
# Each service uses a separate key for isolation
# For Sepolia, replace these with funded Base Sepolia accounts (see bottom block)

# Anvil Account #0 — used for contract deployment + Invite Service signer
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Anvil Account #1 — Client agent
CLIENT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Anvil Account #2 — Provider agent
PROVIDER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Anvil Account #0 — Invite Service (must match InviteRegistrar's inviteSigner)
INVITE_SERVICE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Anvil Account #3 — Recruiter agent
RECRUITER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Contract addresses (filled after deployment, or run ./sync-env.sh)
DID_REGISTRY=
DID_REGISTRAR=
INVITE_REGISTRAR=
IDENTITY_REGISTRY=
REPUTATION_REGISTRY=
VALIDATION_REGISTRY=
USDC_ADDRESS=          # MockERC3009 (Anvil) or real USDC address (Sepolia)

# Provider HTTP server port
PROVIDER_PORT=4021

# Invite Service URL
INVITE_SERVICE_URL=http://127.0.0.1:4060

# x402 payment settings (set X402_ENABLED=false for free dev mode)
X402_ENABLED=true
USDC_PRICE_PER_IMAGE=0.05
# EIP-712 domain of the ERC-3009 token. Defaults match MockERC3009.sol;
# override for real USDC on Base Sepolia (see bottom block).
USDC_NAME=MockERC3009
USDC_VERSION=1
USDC_DECIMALS=6

# ── Base Sepolia (chainId 84532) ────────────────────────────────
# To deploy and run against Base Sepolia instead of Anvil:
#   1. NETWORK=sepolia
#   2. SEPOLIA_RPC_URL=https://sepolia.base.org    (or any Base Sepolia RPC)
#   3. Replace DEPLOYER/CLIENT/PROVIDER/RECRUITER/INVITE_SERVICE_PRIVATE_KEY
#      with funded Base Sepolia accounts.
#        - deployer + provider need Base Sepolia ETH (for gas)
#        - client needs Base Sepolia USDC (https://faucet.circle.com)
#   4. USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e   (Circle official, double-check)
#   5. Override the EIP-712 domain to match real USDC:
#        USDC_NAME="USD Coin"
#        USDC_VERSION="2"
#        USDC_DECIMALS=6
#   6. From repo root: bash deploy-sepolia.sh    (deploys + auto-runs sync-env.sh)
#      sync-env.sh leaves USDC_ADDRESS untouched on real networks.
